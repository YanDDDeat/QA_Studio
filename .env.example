# QA Studio 环境配置模板
# 复制此文件为 .env 并填入实际值：cp .env.example .env

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_NAME=qa_gen

# LLM Provider: "dashscope" or "swust"
LLM_PROVIDER=dashscope

# Per-provider API keys (必填)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
SWUST_API_KEY=your_swust_api_key_here

# LLM overrides (留空则使用provider预设；填LLM_API_KEY可临时覆盖所有provider)
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Auth Configuration
JWT_SECRET=change_this_to_a_random_secret_in_production
JWT_EXPIRE_MINUTES=480

# Admin account (首次启动自动创建)
ADMIN_PASSWORD=change_this_admin_password
ADMIN_INIT_PASSWORD=admin123