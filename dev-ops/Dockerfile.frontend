# QA Studio Frontend - Vue 3 构建镜像
# 只负责构建静态文件，不包含 nginx
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY frontend/package*.json ./

# Install dependencies
RUN npm install

# Copy source code
COPY frontend/ .

# Build for production
RUN npm run build

# 构建产物在 /app/dist 目录
# 通过共享 volume 让 nginx 读取
VOLUME /app/dist

# 这个容器只用于构建，不需要长时间运行
CMD ["sh", "-c", "cp -r /app/dist /output && tail -f /dev/null"]