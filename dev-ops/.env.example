# QA Studio Docker 环境配置
# 复制此文件为 .env 并填入实际值

# MySQL Configuration
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here
MYSQL_DATABASE=qa_gen
MYSQL_USER=qa_user
MYSQL_PASSWORD=your_mysql_password_here

# Backend Configuration
DB_HOST=db
DB_PORT=3306
DB_USER=qa_user
DB_PASSWORD=your_mysql_password_here
DB_NAME=qa_gen

# LLM Provider: "dashscope" or "swust"
LLM_PROVIDER=dashscope

# Per-provider API keys
DASHSCOPE_API_KEY=your_dashscope_api_key_here
SWUST_API_KEY=your_swust_api_key_here

# LLM overrides (留空则使用provider预设；填LLM_API_KEY可临时覆盖所有provider)
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# LLM proxy (可选)
LLM_PROXY=
SWUST_PROXY=

# Auth Configuration
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRE_MINUTES=480

# Admin account (首次启动自动创建)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here
ADMIN_INIT_PASSWORD=admin123